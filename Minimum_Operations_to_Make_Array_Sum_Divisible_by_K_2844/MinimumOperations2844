package Minimum_Operations_to_Make_Array_Sum_Divisible_by_K_2844;

public class MinimumOperations2844 {

    public int minOperations(int[] nums, int k) {
        int sum = 0;

        for (int i = 0; i < nums.length; i++) {
            sum += nums[i];
        }

        return sum % k;
    }

    public static void main(String[] args) {
        MinimumOperations2844 obj = new MinimumOperations2844();

        int[] nums = {3, 9, 7};
        int k = 5;

        int result = obj.minOperations(nums, k);

        System.out.println("Minimum Operations: " + result);
    }
}
